{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "framework": "vite",
  "nodeVersion": "22.x",
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/index.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "^/(?!api).*",
      "dest": "/public/index.html",
      "status": 200
    }
  ],
  "functions": {
    "dist/index.js": {
      "runtime": "nodejs22.x",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
